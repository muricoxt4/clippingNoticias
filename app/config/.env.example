# Groq (obrigatorio)
# Obtenha em: https://console.groq.com
GROQ_API_KEY=

# Google - modo recomendado: Service Account
# 1. Crie uma service account no Google Cloud
# 2. Ative a Google Docs API e a Google Drive API
# 3. Baixe a chave JSON para dentro do projeto
# 4. Compartilhe a pasta de destino com o email da service account
# 5. Para service account sem impersonacao, use uma pasta em Shared Drive
GOOGLE_SERVICE_ACCOUNT_PATH=./credentials/google-credentials.json

# Opcional: use apenas se tiver Google Workspace com domain-wide delegation
# Permite que a service account atue em nome de um usuario real
GOOGLE_IMPERSONATE_USER=

# Fallback: OAuth manual
# Use somente se nao quiser service account
# URI de redirecionamento autorizado: http://localhost:4000/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Pasta do Google Drive onde os Docs serao criados
# Para service account pura, prefira uma pasta dentro de Shared Drive
GOOGLE_DRIVE_FOLDER_ID=

# Compartilhamento do Doc criado
# `restricted` = privado por padrao
# `anyone_reader` = publica para qualquer pessoa com link
GOOGLE_DOC_SHARE_MODE=restricted

# Portais de noticias
NEWS_SITES=https://www.forbes.com.br,https://g1.globo.com,https://www.infomoney.com.br

# Quantos dias retroativos buscar
NEWS_DAYS_BACK=3

# Anti-repeticao
# Historico local consultado antes de enviar artigos para cada persona
NEWS_REPEAT_LOOKBACK_DAYS=14
NEWS_HISTORY_PATH=./data/news-history.json

# Limites do pipeline
# Ajuste para reduzir custo/token ou volume de processamento
MAX_ARTICLES_PER_SITE=20
MAX_ARTICLES_PER_PERSONA=15
