# Groq (obrigatorio)
# Obtenha em: https://console.groq.com
GROQ_API_KEY=

# Google OAuth2 (obrigatorio)
# Crie em: console.cloud.google.com > APIs e Servicos > Credenciais > OAuth 2.0
# Ative as APIs: Google Docs API + Google Drive API
# URI de redirecionamento autorizado: http://localhost:4000/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Pasta do Google Drive onde os Docs serao criados (opcional)
# Abra a pasta no Drive e copie o ID da URL (apos /folders/)
GOOGLE_DRIVE_FOLDER_ID=

# Portais de noticias
NEWS_SITES=https://www.forbes.com.br,https://g1.globo.com,https://www.infomoney.com.br,https://revistapegn.globo.com,https://www.meioemensagem.com.br,https://braziljournal.com,https://exame.com,https://neofeed.com.br

# Quantos dias retroativos buscar
NEWS_DAYS_BACK=3
